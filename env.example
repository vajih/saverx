# Environment variables for SaverX project
# Copy this file to .env and fill in your actual values
# cp env.example .env

# Resend (transactional email — resend.com)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=support@saverx.ai
RESEND_FROM_NAME=SaveRx.ai

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# MailerLite
MAILERLITE_API_KEY=your_mailerlite_api_key_here
MAILERLITE_GROUP_GLP1=
MAILERLITE_GROUP_CARDIO=
MAILERLITE_GROUP_DIABETES=
MAILERLITE_GROUP_GENERAL=
MAILERLITE_GROUP_ALL=
