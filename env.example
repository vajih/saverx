# Environment variables for SaverX project
# Copy this file to .env and fill in your actual values
# cp env.example .env

# Resend (transactional email — resend.com)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=support@saverx.ai
RESEND_FROM_NAME=SaveRx.ai

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Note: RESEND_API_KEY is stored in Google Apps Script Properties, not here.
# See Script Properties in the Apps Script editor for transactional email config.

# Admin Dashboard Auth (set this when deploying to Railway/production)
# Any username works — only the password is checked
ADMIN_PASSWORD=your_strong_password_here

# Katalys Affiliate API (admin dashboard reporting)
# Get key: app.katalys.com → Settings → API Access
KATALYS_API_KEY=kapi-your_key_here

# Google Custom Search API (drug image automation — scripts/fetch-drug-images.py)
# Setup: https://programmablesearchengine.google.com + console.cloud.google.com
GOOGLE_CSE_KEY=AIza...your_google_api_key_here
GOOGLE_CSE_CX=a1b2c3d4...your_search_engine_id_here
